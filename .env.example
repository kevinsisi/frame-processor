# Backend
DATABASE_URL=postgresql+psycopg://frame:frame@postgres:5432/frame_processor
REDIS_URL=redis://redis:6379/0

# Storage root（容器內絕對路徑；對應 docker-compose volume mount）
STORAGE_ROOT=/data

# CORS（前端 dev server）
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
VITE_API_BASE_URL=http://localhost:8000
GEMINI_MODEL=gemini-2.5-flash
